generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Plano {
  id          Int        @id @default(autoincrement())
  nome        String     @db.VarChar(50)
  valorMensal Decimal    @map("valor_mensal") @db.Decimal(10, 2)
  valorAnual  Decimal    @map("valor_anual") @db.Decimal(10, 2)
  softDelete  Boolean    @default(false) @map("soft_delete")
  advogados   Advogado[]

  @@map("plano")
}

model Cliente {
  id            Int               @id @default(autoincrement())
  nome          String            @db.VarChar(255)
  email         String            @unique @db.VarChar(255)
  documento     String            @db.VarChar(20)
  senha         String            @db.VarChar(255)
  dataNascimento DateTime?        @map("data_nascimento") @db.Date
  fotoPath      String?           @map("foto_path") @db.VarChar(255)
  documentoPath String?           @map("documento_path") @db.VarChar(255) // privado: só o dono
  // Dados de contato privados (nunca expostos a terceiros)
  telefone      String?           @db.VarChar(20)
  enderecoLogradouro String?      @map("endereco_logradouro") @db.VarChar(255)
  enderecoNumero String?          @map("endereco_numero") @db.VarChar(20)
  enderecoBairro String?          @map("endereco_bairro") @db.VarChar(100)
  enderecoCidade String?          @map("endereco_cidade") @db.VarChar(100)
  enderecoEstado String?          @map("endereco_estado") @db.VarChar(2)
  enderecoCep   String?           @map("endereco_cep") @db.VarChar(10)
  dataCadastro  DateTime          @default(now()) @map("data_cadastro")
  softDelete    Boolean           @default(false) @map("soft_delete")
  conexoes      ClienteAdvogado[]
  processos     Processo[]

  @@map("cliente")
}

model Advogado {
  id             Int               @id @default(autoincrement())
  nome           String            @db.VarChar(255)
  email          String            @unique @db.VarChar(255)
  senha          String            @db.VarChar(255)
  especializacao String            @db.VarChar(100)
  oab            String            @unique @db.VarChar(20)
  dataCadastro   DateTime          @default(now()) @map("data_cadastro")
  planoId        Int               @map("plano_id")
  assinatura     AssinaturaStatus  @default(ativo)
  nota           Decimal?          @db.Decimal(2, 1) // reputação seedada (0.0-5.0), read-only nesta rodada
  estadoAtuacao  String?           @map("estado_atuacao") @db.VarChar(2)
  cidadeAtuacao  String?           @map("cidade_atuacao") @db.VarChar(100)
  telefone       String?           @db.VarChar(20)
  whatsapp       String?           @db.VarChar(20)
  fotoPath       String?           @map("foto_path") @db.VarChar(255)
  softDelete     Boolean           @default(false) @map("soft_delete")
  plano          Plano             @relation(fields: [planoId], references: [id])
  conexoes       ClienteAdvogado[]
  propostas      Proposta[]
  areas          AdvogadoArea[]
  relatorios     RelatorioCaso[]

  @@map("adv")
}

// Lista controlada de áreas de atuação (seedada). Não usa softDelete — registros fixos.
model Area {
  id        Int            @id @default(autoincrement())
  nome      String         @unique @db.VarChar(50)
  advogados AdvogadoArea[]

  @@map("area")
}

// Join N:N advogado <-> área. Hard delete (sem softDelete): remover área = apagar a linha.
model AdvogadoArea {
  advogadoId Int      @map("id_advogado")
  areaId     Int      @map("id_area")
  advogado   Advogado @relation(fields: [advogadoId], references: [id])
  area       Area     @relation(fields: [areaId], references: [id])

  @@id([advogadoId, areaId])
  @@map("advogado_area")
}

model ClienteAdvogado {
  id          Int      @id @default(autoincrement())
  clienteId   Int      @map("id_cliente")
  advogadoId  Int      @map("id_advogado")
  dataVinculo DateTime @default(now()) @map("data_vinculo")
  softDelete  Boolean  @default(false) @map("soft_delete")
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  advogado    Advogado @relation(fields: [advogadoId], references: [id])

  @@map("cliente_advogado")
}

enum AssinaturaStatus {
  ativo
  pendente
  cancelado
}

model Processo {
  id             Int            @id @default(autoincrement())
  clienteId      Int            @map("id_cliente")
  titulo         String         @db.VarChar(150)
  descricao      String         @db.Text
  especializacao String         @db.VarChar(100)
  status         ProcessoStatus @default(aberto)
  estado         String?        @db.VarChar(2) // herdado do cliente ao publicar, ajustável (filtro de região)
  cidade         String?        @db.VarChar(100)
  dataCriacao    DateTime       @default(now()) @map("data_criacao")
  softDelete     Boolean        @default(false) @map("soft_delete")
  cliente        Cliente        @relation(fields: [clienteId], references: [id])
  propostas      Proposta[]
  relatorios     RelatorioCaso[]

  @@index([especializacao, status, softDelete])
  @@map("processo")
}

// Histórico de relatórios de situação registrados pelo advogado durante o atendimento.
model RelatorioCaso {
  id          Int      @id @default(autoincrement())
  processoId  Int      @map("id_processo")
  advogadoId  Int      @map("id_advogado")
  texto       String   @db.Text
  dataCriacao DateTime @default(now()) @map("data_criacao")
  softDelete  Boolean  @default(false) @map("soft_delete")
  processo    Processo @relation(fields: [processoId], references: [id])
  advogado    Advogado @relation(fields: [advogadoId], references: [id])

  @@index([processoId, softDelete])
  @@map("relatorio_caso")
}

model Proposta {
  id            Int            @id @default(autoincrement())
  processoId    Int            @map("id_processo")
  advogadoId    Int            @map("id_advogado")
  mensagem      String         @db.Text
  valorEstimado Decimal        @map("valor_estimado") @db.Decimal(10, 2)
  status        PropostaStatus @default(pendente)
  dataCriacao   DateTime       @default(now()) @map("data_criacao")
  softDelete    Boolean        @default(false) @map("soft_delete")
  processo      Processo       @relation(fields: [processoId], references: [id])
  advogado      Advogado       @relation(fields: [advogadoId], references: [id])

  @@unique([processoId, advogadoId])
  @@map("proposta")
}

enum ProcessoStatus {
  aberto
  em_atendimento
  encerrado
}

enum PropostaStatus {
  pendente
  aceita
  recusada
}
